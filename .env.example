# =====================
# 服务配置
# =====================

# 知识库数据存储目录
STORAGE_DIR=./data

# =====================
# 索引模型（用于构建知识图谱，推荐用便宜的模型）
# =====================
DEFAULT_INDEX_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_INDEX_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_INDEX_MODEL=deepseek/deepseek-chat

# =====================
# 问答模型（用于生成最终答案）
# =====================
DEFAULT_QUERY_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_QUERY_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_QUERY_MODEL=openai/gpt-4o-mini

# =====================
# 嵌入模型（用于向量检索）
# =====================
DEFAULT_EMBEDDING_BASE_URL=https://api.openai.com/v1
DEFAULT_EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_DIM=1536

# =====================
# 检索配置
# =====================

# 向量相似度阈值，低于此值的结果会被过滤（范围 0.0 - 1.0）
COSINE_THRESHOLD=0.5

# =====================
# 鉴权
# =====================

# 内部服务调用时需在 Header 中携带：Authorization: Bearer <此值>
INTERNAL_SECRET=your-secret-here
